{
  "name": "@jlozano254/hayhayai-core",
  "version": "0.1.0",
  "description": "Framework-agnostic core runtime for hayhayai — semantic annotations, action registry, and AI chat transport",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "chat",
    "semantic",
    "annotations",
    "hayhayai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.1",
    "happy-dom": "^20.9.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
