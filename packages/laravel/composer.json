{
  "name": "hayhayai/laravel",
  "description": "Laravel backend integration for hayhayai — chat endpoint, LLM orchestration, and structured responses",
  "version": "0.1.0",
  "type": "library",
  "keywords": ["laravel", "ai", "chat", "hayhayai"],
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "HayHayAI\\Laravel\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "HayHayAI\\Laravel\\HayhayServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable"
}
