{
  "name": "@jlozano254/hayhayai-vue",
  "version": "0.1.0",
  "description": "Vue 3 adapter for hayhayai — chat panel, launcher, composables, and Inertia integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/vue.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "chat",
    "vue",
    "hayhayai",
    "inertia"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@inertiajs/vue3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@jlozano254/hayhayai-core": "workspace:*",
    "@vitejs/plugin-vue": "^5.2.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vue": "^3.5.13"
  },
  "dependencies": {
    "@jlozano254/hayhayai-core": "workspace:*"
  }
}
